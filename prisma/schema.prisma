// Postgres (Railway) + Prisma. Run: npx prisma migrate dev
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Auth.js (NextAuth) models — required by @auth/prisma-adapter ----
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String? // เก็บเพิ่มตอนสมัคร
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cartItems     CartItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Shop ----
model Product {
  id              Int        @id // ใช้ id เดิมจาก catalogs.ts / products.ts
  category        String // "buy" | "rent" | "software"
  name            String
  description     String
  longDescription String?
  features        String[]
  specs           Json? // [{label:string, value:string}][]
  image           String
  priceTHB        Int? // ราคาเต็ม ex-VAT
  depositTHB      Int? // ราคามัดจำ ex-VAT (null = ใช้ DEPOSIT_THB fallback)
  whtRate         Int        @default(0) // ภาษีหัก ณ ที่จ่าย %: 0 = ไม่หัก, 3 = บริการ, 5 = ซอฟต์แวร์
  hidden          Boolean    @default(false) // ออเดอร์พิเศษ (custom) — ซ่อนจาก /shop, ยัดลงตะกร้า user โดยตรง
  deletedAt       DateTime?  // soft-delete: null = ใช้งาน, มีค่า = อยู่ถังขยะ (ซ่อนจาก shop/cart, กู้คืนได้)
  createdAt       DateTime   @default(now())
  cartItems       CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId Int
  qty       Int      @default(1)
  priceMode String   @default("full") // "full" | "deposit"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId]) // 1 สินค้า/คน — เพิ่มซ้ำ = บวก qty
}

model DiscountCode {
  id         String    @id @default(cuid())
  code       String    @unique // ตั้งค่าผ่าน DB เท่านั้น
  type       String // "percent" | "fixed"
  value      Int // percent: 1-100 | fixed: สตางค์
  active     Boolean   @default(true)
  minAmount  Int? // ยอดขั้นต่ำ (สตางค์)
  usageLimit Int? // จำกัดจำนวนครั้งทั้งหมด (null = ไม่จำกัด)
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Order {
  id              String      @id @default(cuid())
  merchantOrderId String      @unique // ส่งให้ Ksher
  userId          String
  subtotal        Int // สตางค์ ฐานก่อน VAT ก่อนหักส่วนลด
  discountCode    String?
  discountAmount  Int         @default(0) // สตางค์
  baseAmount      Int         @default(0) // ฐานก่อน VAT หลังหักส่วนลด
  vatAmount       Int         @default(0) // VAT 7%
  whtAmount       Int         @default(0) // ภาษีหัก ณ ที่จ่าย (เฉพาะนิติบุคคล)
  total           Int // สตางค์ ยอดจ่ายจริง = base + VAT − WHT
  paymentMethod   String // "ksher_qr" | "ksher_linkpay"
  status          String      @default("pending") // ดู lib/orders.ts (pending|paid|processing|shipped|completed|cancelled|failed)
  ksherReference  String?
  // ใบเสร็จ/ใบกำกับภาษี (optional) — invoiceType null = ไม่ออก
  invoiceType     String? // "personal" | "company"
  invoiceName     String?
  invoiceTaxId    String? // เลขบัตร ปชช. / เลขผู้เสียภาษี 13 หลัก
  invoiceAddress  String? // ที่อยู่ประกอบเป็นบรรทัดเดียว (buildAddressLine)
  invoiceBranch   String? // นิติบุคคล: "สำนักงานใหญ่" / "สาขา ..."
  invoiceEmail    String? // อีเมลสำหรับจัดส่งใบกำกับภาษี
  invoicePhone    String? // เบอร์โทรติดต่อ
  invoiceLineId   String? // LINE ID (optional)
  policyAcceptedAt DateTime? // หลักฐานยอมรับนโยบายสั่งซื้อ/คืนสินค้า (server timestamp ตอนชำระ)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productRef  String // "buy-101" / "rent-5"
  productName String // snapshot
  unitAmount  Int // สตางค์/ชิ้น snapshot (ก่อน VAT)
  qty         Int    @default(1)
  priceMode   String @default("full") // snapshot "full" | "deposit"
  whtRate     Int    @default(0) // snapshot %หัก ณ ที่จ่าย ของชิ้นนี้
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
